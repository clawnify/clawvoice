# ClawVoice Configuration
# Copy to .env and fill in your values

# Voice provider (Deepgram)
DEEPGRAM_API_KEY=

# Telephony provider (Twilio or Telnyx)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TELNYX_API_KEY=
# TELNYX_PUBLIC_KEY=

# OpenClaw gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Optional
# CLAWVOICE_DEBUG=1
